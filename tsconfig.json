{
    "compilerOptions": {
        "paths": {
            "@/*": ["./src/*"],
            "@/components/*": ["./src/components/*"],
            "@/data/*": ["./src/data/*"],
            "@/lib/*": ["./src/lib/*"],
            "@/types/*": ["./src/types/*"]
        }
    },
    "exclude": ["dist", "tmp", "public/pagefind", "public/pagefind/**"],
    "extends": "astro/tsconfigs/strict",
    "include": [".astro/types.d.ts", "**/*"]
}
