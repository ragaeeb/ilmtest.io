{
    "name": "ilmtest.io",
    "type": "module",
    "version": "0.0.1",
    "author": "Ragaeeb Haq",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ragaeeb/ilmtest.io.git"
    },
    "bugs": {
        "url": "https://github.com/ragaeeb/ilmtest.io/issues"
    },
    "homepage": "https://github.com/ragaeeb/ilmtest.io#readme",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "lint": "biome check .",
        "format": "biome check --write .",
        "setup": "bun scripts/setup.ts",
        "clean": "rm -rf src/data src/content/excerpt-chunks dist code_packet.txt",
        "gen-packet": "code2prompt . --include=\"src/**,package.json,astro.config.mjs,README.md,AGENTS.md,docs/deployment.md,scripts/setup.ts,scripts/chunking.ts,scripts/indexing.ts,scripts/mapping.ts,scripts/hierarchy.ts,scripts/env.ts\" -e \"node_modules/**,dist/**,.git/**,bun.lockb,src/data/**,src/content/excerpt-chunks/**,**/*.test.ts\" -O code_packet.txt"
    },
    "dependencies": {
        "@astrojs/react": "^4.4.2",
        "@tailwindcss/vite": "^4.1.18",
        "astro": "^5.16.15",
        "env-var": "^7.5.0",
        "lucide-react": "^0.563.0",
        "marked": "^17.0.1",
        "motion": "^12.29.0",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "tailwindcss": "^4.1.18"
    },
    "engines": {
        "bun": ">=1.3.6",
        "node": ">=25.0.0"
    },
    "packageManager": "bun@1.3.6",
    "devDependencies": {
        "@astrojs/cloudflare": "^12.6.12",
        "@biomejs/biome": "2.3.12",
        "@ilmtest/ilmtest-sdk-js": "^5.0.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.2",
        "@semantic-release/npm": "^13.1.3",
        "@types/bun": "^1.3.6",
        "shamela": "^1.4.2"
    }
}
