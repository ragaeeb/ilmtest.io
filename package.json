{
    "name": "ilmtest.io",
    "type": "module",
    "version": "0.0.5",
    "author": {
        "name": "Ragaeeb Haq",
        "url": "https://github.com/ragaeeb"
    },
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ragaeeb/ilmtest.io.git"
    },
    "bugs": {
        "url": "https://github.com/ragaeeb/ilmtest.io/issues"
    },
    "homepage": "https://github.com/ragaeeb/ilmtest.io",
    "scripts": {
        "dev": "astro dev",
        "build": "astro build",
        "check": "astro check",
        "lint": "biome check .",
        "format": "biome check --write --unsafe .",
        "install-hooks": "bun scripts/installGitHooks.ts",
        "prepare": "bun run install-hooks",
        "baseline": "bun scripts/reportBaseline.ts",
        "setup": "bun scripts/setup.ts",
        "clean": "rm -rf src/data tmp/excerpt-chunks tmp/dataset-build tmp/publish-state tmp/runtime-artifacts dist code_packet.txt",
        "create-r2-bucket": "wrangler r2 bucket create \"$R2_BUCKET\"",
        "upload-r2": "bun scripts/uploadR2.ts",
        "resume": "R2_SKIP_EXISTING=1 R2_REMOTE=1 bun scripts/uploadR2.ts \"$R2_BUCKET\" \"${R2_BASE_DIR:-tmp/excerpt-chunks}\"",
        "deploy": "bun run deploy:prod",
        "deploy:prod": "bun run build && bun scripts/prepareWorkerDeploy.ts prod && wrangler deploy --config dist/functions/wrangler.prod.json",
        "deploy:preview": "bun run build && bun scripts/prepareWorkerDeploy.ts preview && wrangler deploy --config dist/functions/wrangler.preview.json",
        "deploy-check": "bun scripts/prepareWorkerDeploy.ts prod && wrangler deploy --config dist/functions/wrangler.prod.json --dry-run --outdir tmp/wrangler-dry-run",
        "deploy-check:preview": "bun scripts/prepareWorkerDeploy.ts preview && wrangler deploy --config dist/functions/wrangler.preview.json --dry-run --outdir tmp/wrangler-preview-dry-run",
        "publish-dataset": "bun scripts/publishDataset.ts publish",
        "promote-dataset": "bun scripts/publishDataset.ts promote",
        "rollback-dataset": "bun scripts/publishDataset.ts rollback",
        "prune-datasets": "bun scripts/publishDataset.ts prune",
        "validate-dataset": "bun scripts/validateDataset.ts",
        "setup-fixture": "bun scripts/setupFixture.ts",
        "integrity": "bun scripts/checkIntegrity.ts",
        "smoke-routes": "bun scripts/smokeRoutes.ts",
        "runtime-probe": "bun scripts/runtimeProbe.ts",
        "bundle-check": "bun scripts/checkBundle.ts",
        "gen-packet": "code2prompt . --include=\"src/**,package.json,astro.config.mjs,README.md,AGENTS.md,docs/deployment.md,scripts/setup.ts,scripts/chunking.ts,scripts/indexing.ts,scripts/mapping.ts,scripts/hierarchy.ts,scripts/env.ts\" -e \"node_modules/**,dist/**,.git/**,bun.lockb,src/data/**,tmp/excerpt-chunks/**,**/*.test.ts\" -O code_packet.txt"
    },
    "dependencies": {
        "@astrojs/react": "^5.0.0",
        "@tailwindcss/vite": "^4.2.1",
        "astro": "^6.0.4",
        "env-var": "^7.5.0",
        "lucide-react": "^0.577.0",
        "marked": "^17.0.4",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "tailwindcss": "^4.2.1"
    },
    "engines": {
        "bun": ">=1.3.10",
        "node": ">=25.0.0"
    },
    "packageManager": "bun@1.3.10",
    "devDependencies": {
        "@aws-sdk/client-s3": "^3.1007.0",
        "@aws-sdk/lib-storage": "^3.1007.0",
        "@astrojs/check": "^0.9.7",
        "@astrojs/cloudflare": "^13.1.1",
        "@biomejs/biome": "2.4.6",
        "@ilmtest/ilmtest-sdk-js": "^5.0.0",
        "@semantic-release/changelog": "^6.0.3",
        "@semantic-release/git": "^10.0.1",
        "@semantic-release/github": "^12.0.6",
        "@semantic-release/npm": "^13.1.5",
        "@types/bun": "^1.3.10",
        "bitaboom": "^2.5.0",
        "shamela": "^1.5.2",
        "typescript": "^5.9.3",
        "wrangler": "^4.72.0"
    }
}
