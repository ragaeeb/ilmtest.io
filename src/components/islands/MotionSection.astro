---
interface Props {
    delay?: number;
}

const { delay = 0 } = Astro.props;
const animationDelay = `${Math.max(delay, 0)}s`;

void animationDelay;
---

<div class="motion-section" style={`--motion-delay: ${animationDelay};`}>
  <slot />
</div>

<style>
  .motion-section {
    opacity: 0;
    transform: translateY(12px);
    animation: motion-section-enter 0.6s var(--ease-out) var(--motion-delay) forwards;
  }

  @media (prefers-reduced-motion: reduce) {
    .motion-section {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }

  @keyframes motion-section-enter {
    from {
      opacity: 0;
      transform: translateY(12px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
