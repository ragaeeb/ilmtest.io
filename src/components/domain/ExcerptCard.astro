---
import { ExternalLink } from 'lucide-react';
import CitationBlock from '@/components/domain/CitationBlock.astro';
import Card from '@/components/ui/Card.astro';
import { getExcerptLocator } from '@/lib/excerptLocator';
import type { Collection, Excerpt } from '@/types/excerpts';

interface Props {
    excerpt: Excerpt;
    collection: Collection;
    collectionSlug: string;
    sectionSlug: string;
    excerptId: string;
    displayMode?: 'preview' | 'full' | 'arabic' | 'translation';
}

const { excerpt, collection, collectionSlug, sectionSlug, excerptId } = Astro.props as Props;
const displayMode = Astro.props.displayMode ?? 'preview';

const truncateText = (value: string) => (value.length > 150 ? `${value.substring(0, 150)}...` : value);
const showArabicFull = displayMode === 'full' || displayMode === 'arabic';
const showEnglishFull = displayMode === 'full' || displayMode === 'translation';

const arabicText = showArabicFull ? excerpt.nass : truncateText(excerpt.nass);
const englishText = showEnglishFull ? excerpt.text : truncateText(excerpt.text);
const locator = getExcerptLocator(excerpt);
const excerptHref = `/browse/${collectionSlug}/${sectionSlug}/e/${excerptId}`;
const cardHref = displayMode === 'preview' ? excerptHref : undefined;
const isPreviewMode = displayMode === 'preview';

// Biome doesn't see template usage in .astro files.
void excerpt;
void collection;
void collectionSlug;
void sectionSlug;
void excerptId;
void truncateText;
void showArabicFull;
void showEnglishFull;
void arabicText;
void englishText;
void locator;
void excerptHref;
void cardHref;
void isPreviewMode;
void Card;
void CitationBlock;
void ExternalLink;
---

<Card
  href={cardHref}
  variant="outlined"
  hoverable={isPreviewMode}
  padding="md"
  class="excerpt-card-override"
>
  <div class="excerpt-content">
    <div class="excerpt-preview">
      <div class="excerpt-text-arabic" lang="ar" dir="rtl">
        {arabicText}
      </div>
      <div class="excerpt-text-english">
        {englishText}
      </div>
      <div class="excerpt-meta">
        <span class="page-number">{locator.label} {locator.value}</span>
      </div>
      {displayMode === 'full' && <CitationBlock excerpt={excerpt} collection={collection} />}
    </div>
    
    <div class="card-footer">
      {
        isPreviewMode ? (
          <span class="detail-icon" aria-hidden="true">
            <ExternalLink size={14} strokeWidth={2} />
          </span>
        ) : (
          <a class="detail-icon-link" href={excerptHref} aria-label="Open excerpt detail" title="Open excerpt detail">
            <ExternalLink size={14} strokeWidth={2} />
          </a>
        )
      }
    </div>
  </div>
</Card>

<style>
  .excerpt-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .excerpt-text-arabic {
    font-size: 19px;
    color: var(--color-text-primary);
    line-height: 1.8;
    font-family: var(--font-arabic-content);
    direction: rtl;
    text-align: justify;
    white-space: pre-line;
    overflow-wrap: normal;
    word-break: normal;
  }

  .excerpt-text-english {
    font-size: var(--text-base);
    color: var(--color-text-secondary);
    line-height: var(--leading-normal);
    font-family: var(--font-english);
    white-space: pre-wrap;
    overflow-wrap: anywhere;
    word-break: break-word;
  }

  .excerpt-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-tertiary);
  }

  .page-number,
  .hadith-num,
  .volume {
    font-family: var(--font-mono);
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-surface-hover); /* slightly lighter border than main */
  }

  .detail-icon,
  .detail-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.85rem;
    height: 1.85rem;
    border-radius: 999px;
    color: var(--color-primary);
    background: color-mix(in srgb, var(--color-primary) 10%, transparent);
  }

  .detail-icon-link {
    text-decoration: none;
    transition:
      background-color var(--duration-fast) var(--ease-out),
      color var(--duration-fast) var(--ease-out);
  }

  .detail-icon-link:hover {
    color: var(--color-primary-text);
    background: color-mix(in srgb, var(--color-primary) 16%, transparent);
  }

  :global(.card-hoverable:hover) .detail-icon {
    background: color-mix(in srgb, var(--color-primary) 16%, transparent);
  }
</style>
