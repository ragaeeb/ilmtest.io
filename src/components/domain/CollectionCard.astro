---
import Card from '@/components/ui/Card.astro';
import type { Collection } from '@/types/excerpts';
import BilingualText from './BilingualText.astro';

interface Props {
    collection: Collection;
    slug: string;
}

const { collection, slug } = Astro.props;

const authorNames = collection.authors.map((a) => a.name).join(', ');
---

<Card 
  href={`/browse/${slug}`} 
  hoverable={true}
  padding="md"
>
  <div class="collection-content">
    <div class="header-group">
      <h3 class="collection-title">
        {collection.roman}
      </h3>
      <div class="collection-arabic-title">
        <BilingualText 
          text={collection.unwan} 
          isArabic={true} 
        />
      </div>
    </div>

    <div class="meta-group">
      <span class="meta-label">Author:</span> 
      <span class="meta-value">{authorNames}</span>
    </div>

    {collection.roman && (
      <p class="collection-description">
        {/* Placeholder description if none exists in data yet, or just show nothing */}
        Exploring the depths of scholarly tradition.
      </p>
    )}
    
    <div class="action-group">
      <span class="action-text">Browse Collection</span>
      <svg xmlns="http://www.w3.org/2000/svg" class="action-icon" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
      </svg>
    </div>
  </div>
</Card>

<style>
  .collection-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    height: 100%;
  }

  .header-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .collection-title {
    font-size: var(--text-2xl);
    font-weight: 800;
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
    transition: color var(--duration-fast) var(--ease-out);
    margin: 0;
  }

  /* Target the card hover state to change title color - relying on group hover pattern might be tricky with Card component encapsulating styles. 
     But Card renders an <a> tag. So standard CSS nesting works if native nesting is supported or if we rely on global behavior.
     However, scoped styles won't easily reach outside. 
     Button/Card doesn't expose a 'group' class unless passed. Card does pass className.
  */
  :global(.card-hoverable:hover) .collection-title {
    color: var(--color-primary);
  }

  /* Since we can't easily rely on global group hover without adding classes, we'll keep it simple or assume native CSS nesting support in Astro/browsers. */

  .collection-arabic-title {
    font-size: calc(var(--text-xl) * 1.1);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .meta-group {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .meta-label {
    font-weight: 500;
  }

  .collection-description {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
    
    /* Line clamping fallback */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .action-group {
    margin-top: auto;
    padding-top: var(--space-4);
    display: flex;
    align-items: center;
    color: var(--color-primary);
    font-weight: 600;
    font-size: var(--text-base);
  }

  .action-icon {
    width: 16px;
    height: 16px;
    margin-left: 4px;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  :global(.card-hoverable:hover) .action-icon {
    transform: translateX(4px);
  }
</style>
