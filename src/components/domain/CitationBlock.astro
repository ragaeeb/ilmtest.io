---
import { getCitationParts } from '@/lib/citations';
import type { Collection, Excerpt } from '@/types/excerpts';

interface Props {
    excerpt: Excerpt;
    collection: Collection;
}

const { excerpt, collection } = Astro.props as Props;
const citation = getCitationParts(excerpt, collection);

// Biome doesn't see template usage in .astro files.
void excerpt;
void collection;
void citation;
void getCitationParts;
---

<div class="citation-block">
  <div class="citation-content">
    <span class="citation-label">Source:</span>
    <a
      class="citation-link"
      href={citation.url}
      target="_blank"
      rel="noreferrer"
    >
      [{citation.label}]
    </a>
  </div>
</div>

<style>
  .citation-block {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .citation-content {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .citation-label {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .citation-link {
    color: var(--color-text-secondary);
    text-decoration: none;
  }

  .citation-link:hover {
    color: var(--color-primary-text);
    text-decoration: underline;
  }
</style>
