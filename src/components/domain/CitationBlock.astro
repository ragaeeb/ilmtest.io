---
import { formatCitation } from '@/lib/citations';
import type { CitationMeta, Collection, Excerpt } from '@/types/excerpts';

interface Props {
    excerpt: Excerpt;
    collection: Collection;
}

const { excerpt, collection } = Astro.props;
const citation = formatCitation(excerpt, collection);
---

<div class="citation-block">
  <div class="citation-content">
    <span class="citation-label">Source:</span>
    <Fragment set:html={citation} />
  </div>
</div>

<style>
  .citation-block {
    margin-top: var(--space-4);
    padding-top: var(--space-4);
    border-top: 1px solid var(--color-border);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .citation-content {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .citation-label {
    font-weight: 500;
    color: var(--color-text-primary);
  }
</style>
