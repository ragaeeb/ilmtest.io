---
import MotionSection from '../components/islands/MotionSection.astro';
import { ThemeToggle } from '../components/islands/ThemeToggle';
import Footer from '../components/layout/Footer.astro';
import Header from '../components/layout/Header.astro';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

// Biome doesn't see template usage in .astro files.
void ThemeToggle;
void MotionSection;
void Footer;
void Header;
void Button;
void Card;
void BaseLayout;
---

<BaseLayout title="Home" description="Authentic Islamic content with verification and scholarly sources.">
  <Header slot="header" currentPath="/">
    <ThemeToggle client:only="react" slot="theme-toggle" />
  </Header>

  <MotionSection>
    <div class="hero">
      <div class="hero-content">
        <h1 class="hero-title text-4xl font-bold text-blue-500">
          <span class="hero-ilm">Ilm</span><span class="hero-test">Test</span>
        </h1>
        <p class="hero-tagline">
          Authentic Islamic content with verification and scholarly sources.
        </p>
        <div class="hero-actions">
          <Button href="/browse" variant="primary" size="lg">
            Browse Collections
          </Button>
          <Button href="/about" variant="secondary" size="lg">
            Learn More
          </Button>
        </div>
      </div>
    </div>
  </MotionSection>

  <MotionSection delay={0.1}>
    <section class="features">
      <div class="features-grid">
        <Card variant="elevated" hoverable>
          <div class="feature-icon">📚</div>
          <h3 class="feature-title">Curated Collections</h3>
          <p class="feature-desc">
            Access carefully curated Islamic texts with authentic translations.
          </p>
        </Card>

        <Card variant="elevated" hoverable>
          <div class="feature-icon">✓</div>
          <h3 class="feature-title">Verified Sources</h3>
          <p class="feature-desc">
            Every citation linked to its original source for verification.
          </p>
        </Card>

        <Card variant="elevated" hoverable>
          <div class="feature-icon">🌍</div>
          <h3 class="feature-title">Bilingual Display</h3>
          <p class="feature-desc">
            Side-by-side Arabic and English for comparative study.
          </p>
        </Card>
      </div>
    </section>
  </MotionSection>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: var(--space-12) var(--space-6);
    text-align: center;
    background: linear-gradient(
      180deg,
      var(--color-background) 0%,
      var(--color-surface) 100%
    );
  }

  .hero-content {
    max-width: 600px;
  }

  .hero-title {
    font-size: var(--text-4xl);
    margin-bottom: var(--space-4);
  }

  .hero-ilm {
    color: var(--color-primary);
  }

  .hero-test {
    color: var(--color-secondary);
  }

  .hero-tagline {
    font-size: var(--text-xl);
    color: var(--color-text-secondary);
    margin-bottom: var(--space-8);
    line-height: var(--leading-relaxed);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-4);
    justify-content: center;
    flex-wrap: wrap;
  }

  .features {
    padding: var(--space-16) var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-6);
  }

  .feature-icon {
    font-size: 2.5rem;
    margin-bottom: var(--space-4);
  }

  .feature-title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
    color: var(--color-text-primary);
  }

  .feature-desc {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  @media (max-width: 640px) {
    .hero-title {
      font-size: var(--text-3xl);
    }

    .hero-tagline {
      font-size: var(--text-lg);
    }

    .hero-actions {
      flex-direction: column;
    }
  }
</style>
