---
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Card from '@/components/ui/Card.astro';
// Import collections data
import collectionsData from '@/data/collections.json';
import indexes from '@/data/indexes.json';
import BaseLayout from '@/layouts/BaseLayout.astro';
import type { Collection } from '@/types/excerpts';

// Type the imported data
const collections = collectionsData as Collection[];

// Enhance with section counts
const collectionsWithCounts = collections.map((collection) => ({
    ...collection,
    sectionCount: indexes.collectionToSections?.[collection.id]?.length || 0,
}));
---

<BaseLayout
    title="Browse Collections"
    description="Explore Islamic texts with verified translations and scholarly sources."
>
    <Header slot="header" currentPath="/browse">
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <div class="browse-container">
        <header class="browse-header">
            <h1>Browse Collections</h1>
            <p class="subtitle">
                Explore carefully curated Islamic texts with authentic translations.
            </p>
        </header>

        <div class="collections-grid">
            {
                collectionsWithCounts.map((collection) => (
                    <Card variant="elevated" hoverable href={`/browse/${collection.slug}`}>
                        <div class="collection-header">
                            <h3 class="collection-title-arabic" lang="ar" dir="rtl">
                                {collection.unwan}
                            </h3>
                            <h3 class="collection-title">{collection.roman}</h3>
                        </div>
                        {collection.authors.length > 0 && (
                            <p class="collection-author">
                                by {collection.authors.map((a) => a.name).join(', ')}
                            </p>
                        )}
                        <div class="collection-meta">
                            <span class="section-count">{collection.sectionCount} sections</span>
                        </div>
                    </Card>
                ))
            }
        </div>
    </div>

    <Footer slot="footer" />
</BaseLayout>

<style>
    .browse-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--space-12) var(--space-6);
    }

    .browse-header {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .browse-header h1 {
        font-size: var(--text-4xl);
        margin-bottom: var(--space-4);
        color: var(--color-text-primary);
    }

    .subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-secondary);
        max-width: 600px;
        margin: 0 auto;
    }

    .collections-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: var(--space-6);
    }

    .collection-header {
        margin-bottom: var(--space-4);
    }

    .collection-title-arabic {
        font-family: var(--font-arabic-content);
        font-size: var(--text-xl);
        line-height: var(--leading-arabic);
        margin-bottom: var(--space-2);
        color: var(--color-text-primary);
    }

    .collection-title {
        font-size: var(--text-xl);
        margin-bottom: var(--space-2);
        color: var(--color-text-primary);
    }

    .collection-author {
        color: var(--color-text-secondary);
        font-size: var(--text-sm);
        margin-bottom: var(--space-4);
        font-style: italic;
    }

    .collection-meta {
        display: flex;
        gap: var(--space-4);
        color: var(--color-text-tertiary);
        font-size: var(--text-sm);
        padding-top: var(--space-3);
        border-top: 1px solid var(--color-border);
    }

    .section-count {
        display: flex;
        align-items: center;
        gap: var(--space-1);
    }

    @media (max-width: 768px) {
        .browse-header h1 {
            font-size: var(--text-3xl);
        }

        .collections-grid {
            grid-template-columns: 1fr;
        }
    }
</style>