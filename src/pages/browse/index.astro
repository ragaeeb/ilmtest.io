---
export const prerender = false;

import CollectionCard from '@/components/domain/CollectionCard.astro';
import { SearchDialog } from '@/components/islands/SearchDialog';
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import RuntimeUnavailableLayout from '@/layouts/RuntimeUnavailableLayout.astro';
import { loadCollectionsData } from '@/lib/data';
import { isRuntimeDataError } from '@/lib/runtimeErrors';

let collectionsWithCounts: Awaited<ReturnType<typeof loadCollectionsData>> = [];
let runtimeUnavailable = false;

try {
    collectionsWithCounts = await loadCollectionsData(Astro.request.url);
} catch (error) {
    if (!isRuntimeDataError(error)) {
        throw error;
    }

    runtimeUnavailable = true;
    Astro.response.status = error.statusCode;
    Astro.response.headers.set('Cache-Control', 'no-store');
    Astro.response.headers.set('CDN-Cache-Control', 'no-store');
}

if (!runtimeUnavailable) {
    Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
    Astro.response.headers.set('CDN-Cache-Control', 'max-age=3600');
}
---

{
    runtimeUnavailable ? (
        <RuntimeUnavailableLayout title="Browse unavailable" message="Collection metadata could not be loaded from the active dataset." />
    ) : (
        <BaseLayout
            title="Browse Collections"
            description="Explore Islamic texts with verified translations and scholarly sources."
        >
            <Header slot="header" currentPath="/browse">
                <SearchDialog client:idle slot="search" />
                <ThemeToggle client:only="react" slot="theme-toggle" />
            </Header>

            <div class="browse-container">
                <header class="browse-header">
                    <h1>Browse Collections</h1>
                    <p class="subtitle">
                        Explore carefully curated Islamic texts with authentic translations.
                    </p>
                </header>

                <div class="collections-grid">
                    {
                        collectionsWithCounts.map((collection) => (
                            <CollectionCard collection={collection} slug={collection.slug} />
                        ))
                    }
                </div>
            </div>

            <Footer slot="footer" />
        </BaseLayout>
    )
}

<style>
    .browse-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: var(--space-12) var(--space-6);
    }

    .browse-header {
        text-align: center;
        margin-bottom: var(--space-12);
    }

    .browse-header h1 {
        font-size: var(--text-4xl);
        margin-bottom: var(--space-4);
        color: var(--color-text-primary);
    }

    .subtitle {
        font-size: var(--text-lg);
        color: var(--color-text-secondary);
        max-width: 600px;
        margin: 0 auto;
    }

    .collections-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
        gap: var(--space-8);
    }

    @media (max-width: 768px) {
        .browse-header h1 {
            font-size: var(--text-3xl);
        }

        .collections-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
