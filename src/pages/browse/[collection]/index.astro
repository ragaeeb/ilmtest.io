---
// Enable SSR for this route
export const prerender = false;

import { SearchDialog } from '@/components/islands/SearchDialog';
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import Card from '@/components/ui/Card.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import RuntimeUnavailableLayout from '@/layouts/RuntimeUnavailableLayout.astro';
import { loadCollectionPageData } from '@/lib/data';
import { isRuntimeDataError } from '@/lib/runtimeErrors';

const { collection: collectionSlug } = Astro.params;

if (!collectionSlug) {
    return Astro.redirect('/404');
}

const url = new URL(Astro.request.url, 'https://ilmtest.io');
const pageParam = Number(url.searchParams.get('page') ?? '1');
const normalizedPage = Number.isFinite(pageParam) ? pageParam : 1;
let pageData: Awaited<ReturnType<typeof loadCollectionPageData>> = null;
let runtimeUnavailable = false;

try {
    pageData = await loadCollectionPageData(collectionSlug, normalizedPage, Astro.request.url);
} catch (error) {
    if (!isRuntimeDataError(error)) {
        throw error;
    }

    runtimeUnavailable = true;
    Astro.response.status = error.statusCode;
    Astro.response.headers.set('Cache-Control', 'no-store');
    Astro.response.headers.set('CDN-Cache-Control', 'no-store');
}

if (!runtimeUnavailable && !pageData) {
    return Astro.redirect('/browse');
}

const buildPageHref = (page: number) =>
    page <= 1 ? `/browse/${collectionSlug}` : `/browse/${collectionSlug}?page=${page}`;
const breadcrumbItems = pageData ? [{ label: 'Browse', href: '/browse' }, { label: pageData.collection.roman }] : [];
const hasPrevPage = pageData ? pageData.currentPage > 1 : false;
const hasNextPage = pageData ? pageData.currentPage < pageData.totalPages : false;

if (!runtimeUnavailable) {
    Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
    Astro.response.headers.set('CDN-Cache-Control', 'max-age=3600');
}
---

{
runtimeUnavailable || !pageData ? (
    <RuntimeUnavailableLayout
        title="Collection unavailable"
        message="The active dataset is missing collection browse metadata for this route."
        backHref="/browse"
    />
) : (
<BaseLayout title={pageData.collection.roman} description={`Browse ${pageData.collection.roman}`}>
    <Header slot="header" currentPath="/browse">
        <SearchDialog client:idle slot="search" />
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <div class="collection-container">
        <Breadcrumb items={breadcrumbItems} />

        <header class="collection-header">
            <h1 class="collection-title-arabic" lang="ar" dir="rtl">
                {pageData.collection.unwan}
            </h1>
            <h1>{pageData.collection.roman}</h1>
            {pageData.collection.authors.length > 0 && (
                <p class="author-name">
                    by{' '}
                    {pageData.collection.authors.map((author, index) => (
                        <>
                            {index > 0 ? ', ' : ''}
                            <a class="author-link" href={`/profile/${author.id}`}>
                                {author.name}
                            </a>
                        </>
                    ))}
                </p>
            )}
            <p class="subtitle">
                {pageData.totalSections} sections · Page {pageData.currentPage} of {pageData.totalPages}
            </p>
        </header>

        <div class="sections-list">
            {
                pageData.sectionItems.map((section) => (
                    <Card variant="outlined" hoverable href={`/browse/${collectionSlug}/${section.sectionId}`}>
                        <div class="section-content">
                            <div class="section-titles">
                                {section.titleArabic && (
                                    <h3 class="section-title-arabic" lang="ar" dir="rtl">
                                        {section.titleArabic}
                                    </h3>
                                )}
                                <h3 class="section-title">{section.title}</h3>
                            </div>
                            <div class="section-meta">
                                <span>{section.excerptCount} excerpts</span>
                            </div>
                        </div>
                    </Card>
                ))
            }
        </div>

        <nav class="pagination" aria-label="Section pages">
            <a
                class:list={["pagination-link", !hasPrevPage && "is-disabled"]}
                href={hasPrevPage ? buildPageHref(pageData.currentPage - 1) : undefined}
                aria-disabled={!hasPrevPage}
            >
                Previous
            </a>
            <span class="pagination-info">Page {pageData.currentPage} of {pageData.totalPages}</span>
            <a
                class:list={["pagination-link", !hasNextPage && "is-disabled"]}
                href={hasNextPage ? buildPageHref(pageData.currentPage + 1) : undefined}
                aria-disabled={!hasNextPage}
            >
                Next
            </a>
        </nav>
    </div>

    <Footer slot="footer" />
</BaseLayout>
)
}

<style>
    .collection-container {
        max-width: 900px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    .collection-header {
        margin: var(--space-8) 0;
        text-align: center;
    }

    .collection-title-arabic {
        font-family: var(--font-arabic-content);
        font-size: var(--text-3xl);
        font-weight: 400;
        line-height: 1.4;
        margin-bottom: var(--space-3);
        color: var(--color-text-primary);
    }

    .collection-header h1 {
        font-size: var(--text-3xl);
        margin-bottom: var(--space-3);
    }

    .author-name {
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
        font-style: italic;
        margin-bottom: var(--space-2);
    }

    .author-link {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 2px;
    }

    .author-link:hover {
        color: var(--color-primary);
    }

    .subtitle {
        color: var(--color-text-secondary);
        font-size: var(--text-lg);
    }

    .sections-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .section-content {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: var(--space-4);
    }

    .section-titles {
        flex: 1;
    }

    .section-title-arabic {
        font-family: var(--font-arabic-content);
        font-size: var(--text-xl);
        font-weight: 400;
        line-height: 1.5;
        margin-bottom: var(--space-2);
        color: var(--color-text-primary);
    }

    .section-title {
        font-size: var(--text-lg);
        font-weight: 600;
        color: var(--color-text-primary);
    }

    .section-meta {
        color: var(--color-text-tertiary);
        font-size: var(--text-sm);
        white-space: nowrap;
    }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .pagination-link {
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--color-border);
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .pagination-link:hover {
    color: var(--color-primary-text);
    border-color: var(--color-border-hover);
  }

  .pagination-link.is-disabled {
    opacity: 0.5;
    pointer-events: none;
  }

  .pagination-info {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

    @media (max-width: 640px) {
        .section-content {
            flex-direction: column;
        }

        .section-meta {
            align-self: flex-start;
        }
    }
</style>
