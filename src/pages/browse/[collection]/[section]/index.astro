---
// Enable SSR for this route
export const prerender = false;

import { BookOpen, Eye, FileText, Languages } from 'lucide-react';
import ExcerptCard from '@/components/domain/ExcerptCard.astro';
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import RuntimeUnavailableLayout from '@/layouts/RuntimeUnavailableLayout.astro';
import { loadSectionPageData } from '@/lib/data';
import { isRuntimeDataError } from '@/lib/runtimeErrors';
import type { Excerpt } from '@/types/excerpts';

const { collection: collectionSlug, section } = Astro.params;

if (!collectionSlug || !section) {
    return Astro.redirect('/404');
}

let sectionData: Awaited<ReturnType<typeof loadSectionPageData>> = null;
let runtimeUnavailable = false;

try {
    sectionData = await loadSectionPageData(collectionSlug, section, Astro.request.url);
} catch (error) {
    if (!isRuntimeDataError(error)) {
        throw error;
    }

    runtimeUnavailable = true;
    Astro.response.status = error.statusCode;
    Astro.response.headers.set('Cache-Control', 'no-store');
    Astro.response.headers.set('CDN-Cache-Control', 'no-store');
}

if (!runtimeUnavailable && !sectionData) {
    return Astro.redirect('/browse');
}
const sectionTitle = sectionData?.sectionSummary.title || `Section ${section}`;
const sectionTitleArabic = sectionData?.sectionSummary.titleArabic || '';
const requestedView = Astro.url.searchParams.get('view');
const excerptDisplayMode = ['preview', 'full', 'arabic', 'translation'].includes(requestedView ?? '')
    ? (requestedView as 'preview' | 'full' | 'arabic' | 'translation')
    : 'full';
const previewHref = `/browse/${collectionSlug}/${section}?view=preview`;
const fullHref = `/browse/${collectionSlug}/${section}`;
const arabicHref = `/browse/${collectionSlug}/${section}?view=arabic`;
const translationHref = `/browse/${collectionSlug}/${section}?view=translation`;

const breadcrumbItems = [
    { label: 'Browse', href: '/browse' },
    { label: sectionData?.collection.roman ?? 'Collection', href: `/browse/${collectionSlug}` },
    { label: sectionTitle },
];

// Biome doesn't see template usage in .astro files.
void ExcerptCard;
void ThemeToggle;
void Footer;
void Header;
void Breadcrumb;
void BaseLayout;
void sectionData;
void sectionTitleArabic;
void breadcrumbItems;
void excerptDisplayMode;
void previewHref;
void fullHref;
void arabicHref;
void translationHref;
void BookOpen;
void Eye;
void FileText;
void Languages;

if (!runtimeUnavailable) {
    Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
    Astro.response.headers.set('CDN-Cache-Control', 'max-age=3600');
}
---

{
runtimeUnavailable || !sectionData ? (
    <RuntimeUnavailableLayout
        title="Section unavailable"
        message="The active dataset is missing section browse artifacts for this route."
        backHref={`/browse/${collectionSlug}`}
    />
) : (
<BaseLayout title={sectionTitle} description={`Browse excerpts from ${sectionTitle}`}>
    <Header slot="header" currentPath="/browse">
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <div class="section-container">
        <Breadcrumb items={breadcrumbItems} />

        <header class="section-header">
            {
                sectionTitleArabic && (
                    <h1 class="section-title-arabic" lang="ar" dir="rtl">
                        {sectionTitleArabic}
                    </h1>
                )
            }
            <h1 class="section-title">{sectionTitle}</h1>
            <div class="section-meta">
                <p class="subtitle">{sectionData.excerpts.length} excerpts</p>
                <nav class="view-toggle" aria-label="Excerpt display mode">
                    <a
                        href={fullHref}
                        class:list={['view-toggle-link', excerptDisplayMode === 'full' && 'is-active']}
                        aria-current={excerptDisplayMode === 'full' ? 'page' : undefined}
                        aria-label="Show full text"
                        title="Show full text"
                    >
                        <FileText size={14} strokeWidth={2} />
                    </a>
                    <a
                        href={previewHref}
                        class:list={['view-toggle-link', excerptDisplayMode === 'preview' && 'is-active']}
                        aria-current={excerptDisplayMode === 'preview' ? 'page' : undefined}
                        aria-label="Show preview text"
                        title="Show preview text"
                    >
                        <Eye size={14} strokeWidth={2} />
                    </a>
                    <a
                        href={arabicHref}
                        class:list={['view-toggle-link', excerptDisplayMode === 'arabic' && 'is-active']}
                        aria-current={excerptDisplayMode === 'arabic' ? 'page' : undefined}
                        aria-label="Show Arabic text"
                        title="Show Arabic text"
                    >
                        <BookOpen size={14} strokeWidth={2} />
                    </a>
                    <a
                        href={translationHref}
                        class:list={['view-toggle-link', excerptDisplayMode === 'translation' && 'is-active']}
                        aria-current={excerptDisplayMode === 'translation' ? 'page' : undefined}
                        aria-label="Show translation text"
                        title="Show translation text"
                    >
                        <Languages size={14} strokeWidth={2} />
                    </a>
                </nav>
            </div>
        </header>

        <div class="excerpts-list">
            {
                sectionData.excerpts.map((excerpt) => (
                    <ExcerptCard
                        excerpt={excerpt as Excerpt}
                        collection={sectionData.collection}
                        collectionSlug={collectionSlug}
                        sectionSlug={section}
                        excerptId={excerpt.id}
                        displayMode={excerptDisplayMode}
                    />
                ))
            }
        </div>
    </div>

    <div id="excerpt-loading-overlay" class="excerpt-loading-overlay" aria-hidden="true">
        <div class="excerpt-loading-card" role="status" aria-live="polite">
            <div class="excerpt-loading-spinner" aria-hidden="true"></div>
            <span>Loading excerpt…</span>
        </div>
    </div>

    <Footer slot="footer" />
</BaseLayout>
)
}

<script>
    const overlay = document.getElementById('excerpt-loading-overlay');
    const excerptsList = document.querySelector('.excerpts-list');

    if (overlay && excerptsList) {
        excerptsList.addEventListener('click', (event) => {
            if (!(event instanceof MouseEvent)) {
                return;
            }

            const target = event.target;
            if (!(target instanceof HTMLElement)) {
                return;
            }

            const link = target.closest('.excerpts-list a');
            if (!link) {
                return;
            }

            if (event.defaultPrevented || event.button !== 0 || event.metaKey || event.ctrlKey || event.shiftKey) {
                return;
            }

            overlay.classList.add('is-visible');
            overlay.setAttribute('aria-hidden', 'false');
        });
    }
</script>

<style>
    .section-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    .section-header {
        margin: var(--space-8) 0;
        text-align: center;
    }

    .section-title-arabic {
        font-family: var(--font-arabic-content);
        font-size: var(--text-3xl);
        font-weight: 400;
        line-height: 1.4;
        margin-bottom: var(--space-4);
        color: var(--color-text-primary);
    }

    .section-title {
        font-size: var(--text-2xl);
        margin-bottom: var(--space-3);
        color: var(--color-text-primary);
    }

    .subtitle {
        color: var(--color-text-secondary);
        font-size: var(--text-base);
        margin: 0;
    }

    .section-meta {
        display: inline-flex;
        align-items: center;
        gap: var(--space-2);
        margin-top: var(--space-2);
        flex-wrap: wrap;
        justify-content: center;
    }

    .view-toggle {
        display: inline-flex;
        align-items: center;
        gap: 2px;
        padding: 3px;
        border: 1px solid color-mix(in srgb, var(--color-border) 85%, transparent);
        border-radius: 999px;
        background: color-mix(in srgb, var(--color-surface) 92%, var(--color-background));
    }

    .view-toggle-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.9rem;
        height: 1.9rem;
        border-radius: 999px;
        color: var(--color-text-secondary);
        text-decoration: none;
        transition:
            background-color var(--duration-fast) var(--ease-out),
            color var(--duration-fast) var(--ease-out);
    }

    .view-toggle-link:hover {
        color: var(--color-text-primary);
        background: var(--color-surface-hover);
    }

    .view-toggle-link.is-active {
        background: color-mix(in srgb, var(--color-primary) 14%, var(--color-surface));
        color: var(--color-primary);
    }

    .excerpts-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .excerpt-loading-overlay {
        position: fixed;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        background: color-mix(in srgb, var(--color-background) 70%, transparent);
        backdrop-filter: blur(6px);
        opacity: 0;
        pointer-events: none;
        transition: opacity var(--duration-fast) var(--ease-out);
        z-index: var(--z-sticky);
    }

    .excerpt-loading-overlay.is-visible {
        opacity: 1;
        pointer-events: all;
    }

    .excerpt-loading-card {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        padding: var(--space-4) var(--space-6);
        background: var(--color-surface);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        font-size: var(--text-sm);
        color: var(--color-text-secondary);
    }

    .excerpt-loading-spinner {
        width: 18px;
        height: 18px;
        border-radius: 999px;
        border: 2px solid var(--color-border);
        border-top-color: var(--color-primary);
        animation: excerptSpin 0.7s linear infinite;
    }

    @keyframes excerptSpin {
        to {
            transform: rotate(360deg);
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .excerpt-loading-spinner {
            animation: none;
        }
    }

    @media (max-width: 640px) {
        .section-title-arabic {
            font-size: var(--text-2xl);
        }

        .section-title {
            font-size: var(--text-xl);
        }

        .section-meta {
            flex-direction: column;
            gap: var(--space-2);
        }
    }
</style>
