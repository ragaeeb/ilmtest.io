---
// Enable SSR for this route
export const prerender = false;

import ExcerptCard from '@/components/domain/ExcerptCard.astro';
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { loadCollectionsData, loadIndexesData } from '@/lib/data';
import { fetchExcerptChunk } from '@/lib/excerptChunks';
import { arabicToWestern } from '@/lib/textUtils';
import type { Collection, Excerpt } from '@/types/excerpts';

const { collection: collectionSlug, section } = Astro.params;

if (!collectionSlug || !section) {
    return Astro.redirect('/404');
}

// Find collection metadata
const collectionsData = loadCollectionsData();
const indexesData = loadIndexesData();
const indexes = indexesData as Record<string, any>;
const collections = Array.isArray(collectionsData)
    ? (collectionsData as Collection[])
    : ((collectionsData as { collections?: Collection[] }).collections ?? []);
const collectionData = collections.find((c) => c.slug === collectionSlug);

if (!collectionData) {
    return Astro.redirect('/browse');
}

const sectionMap = (indexes.sectionToExcerpts?.[collectionData.id] || {}) as Record<string, string[]>;

// Get excerpts for this section
const excerptIds = (sectionMap[section] || []) as string[];

if (excerptIds.length === 0) {
    return Astro.redirect(`/browse/${collectionSlug}`);
}

const sectionChunkIds = (indexes.sectionToChunks?.[collectionData.id] || {}) as Record<string, string[]>;
const chunkIds = sectionChunkIds[section] || [];
const sectionChunks = (
    await Promise.all(chunkIds.map((chunkId) => fetchExcerptChunk(chunkId, Astro.request.url)))
).filter((chunk): chunk is NonNullable<typeof chunk> => Boolean(chunk));

if (sectionChunks.length === 0) {
    return Astro.redirect(`/browse/${collectionSlug}`);
}

const headingIdSet = new Set(Object.keys(sectionMap));

// Extract all excerpts from chunks and filter out heading markers
const excerpts = sectionChunks
    .flatMap((chunk) => chunk.excerpts)
    .filter((excerpt) => {
        const excerptId = String(excerpt.id);
        const hasContent = typeof excerpt.nass === 'string' && excerpt.nass.trim().length > 0;
        return !headingIdSet.has(excerptId) && hasContent;
    })
    .sort((a, b) => a.from - b.from);

// Get the section heading
const headingExcerpt = sectionChunks.flatMap((chunk) => chunk.excerpts).find((excerpt) => excerpt.id === section);

const sectionTitle = headingExcerpt?.text || `Section ${section}`;
const sectionTitleArabic = headingExcerpt?.nass || '';

const breadcrumbItems = [
    { label: 'Browse', href: '/browse' },
    { label: collectionData.roman, href: `/browse/${collectionSlug}` },
    { label: sectionTitle },
];

// Biome doesn't see template usage in .astro files.
const _typeCheck = null as unknown as Collection | Excerpt;
void _typeCheck;
void ExcerptCard;
void ThemeToggle;
void Footer;
void Header;
void Breadcrumb;
void BaseLayout;
void arabicToWestern;
void excerpts;
void sectionTitleArabic;
void breadcrumbItems;

// Set cache headers for edge caching
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
Astro.response.headers.set('CDN-Cache-Control', 'max-age=3600');
---

<BaseLayout title={sectionTitle} description={`Browse excerpts from ${sectionTitle}`}>
    <Header slot="header" currentPath="/browse">
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <div class="section-container">
        <Breadcrumb items={breadcrumbItems} />

        <header class="section-header">
            {
                sectionTitleArabic && (
                    <h1 class="section-title-arabic" lang="ar" dir="rtl">
                        {sectionTitleArabic}
                    </h1>
                )
            }
            <h1 class="section-title">{sectionTitle}</h1>
            <p class="subtitle">{excerpts.length} excerpts</p>
        </header>

        <div class="excerpts-list">
            {
                excerpts.map((excerpt) => (
                    <ExcerptCard
                        excerpt={excerpt as Excerpt}
                        collection={collectionData}
                        collectionSlug={collectionSlug}
                        sectionSlug={section}
                        excerptId={excerpt.id}
                    />
                ))
            }
        </div>
    </div>

    <Footer slot="footer" />
</BaseLayout>

<style>
    .section-container {
        max-width: 1100px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    .section-header {
        margin: var(--space-8) 0;
        text-align: center;
    }

    .section-title-arabic {
        font-family: var(--font-arabic-content);
        font-size: var(--text-3xl);
        line-height: var(--leading-arabic);
        margin-bottom: var(--space-4);
        color: var(--color-text-primary);
    }

    .section-title {
        font-size: var(--text-2xl);
        margin-bottom: var(--space-3);
        color: var(--color-text-primary);
    }

    .subtitle {
        color: var(--color-text-secondary);
        font-size: var(--text-base);
    }

    .excerpts-list {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    @media (max-width: 640px) {
        .section-title-arabic {
            font-size: var(--text-2xl);
        }

        .section-title {
            font-size: var(--text-xl);
        }
    }
</style>
