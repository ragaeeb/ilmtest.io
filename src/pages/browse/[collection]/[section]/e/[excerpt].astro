---
// Enable SSR for this route
export const prerender = false;

import { marked } from 'marked';
import BilingualText from '@/components/domain/BilingualText.astro';
import CitationBlock from '@/components/domain/CitationBlock.astro';
import ShareButton from '@/components/islands/ShareButton.astro';
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import Breadcrumb from '@/components/ui/Breadcrumb.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCitationParts } from '@/lib/citations';
import { loadCollectionsData, loadIndexesData, loadTranslatorsData } from '@/lib/data';
import { fetchExcerptChunk } from '@/lib/excerptChunks';
import { arabicToWestern } from '@/lib/textUtils';
import type { Collection, Excerpt } from '@/types/excerpts';

const { collection: collectionSlug, section, excerpt: excerptId } = Astro.params;

if (!collectionSlug || !section || !excerptId) {
    return Astro.redirect('/404');
}

// Find collection metadata
const collectionsData = loadCollectionsData();
const indexesData = loadIndexesData();
const translatorsData = loadTranslatorsData();
const indexes = indexesData as Record<string, any>;

function getCollections(): Collection[] {
    if (Array.isArray(collectionsData)) {
        return collectionsData as Collection[];
    }
    return (collectionsData as { collections?: Collection[] }).collections ?? [];
}

const collections = getCollections();
const collectionData = collections.find((c) => c.slug === collectionSlug);

if (!collectionData) {
    return Astro.redirect('/browse');
}

const sectionMap = (indexes.sectionToExcerpts?.[collectionData.id] || {}) as Record<string, string[]>;

// Verify this excerpt belongs to this section
const sectionExcerptIds = new Set((sectionMap[section] || []) as string[]);
if (!sectionExcerptIds.has(excerptId)) {
    return Astro.redirect('/404');
}

const excerptToChunk = (indexes.excerptToChunk?.[collectionData.id] || {}) as Record<string, string>;
const chunkId = excerptToChunk[excerptId];
const sectionExcerptList = (sectionMap[section] || []) as string[];

const requestUrl = Astro.request.url;
const initialChunk = chunkId ? await fetchExcerptChunk(chunkId, requestUrl) : null;
let excerpt = initialChunk?.excerpts.find((e) => e.id === excerptId);

if (!excerpt) {
    return Astro.redirect(`/browse/${collectionSlug}/${section}`);
}

// Get the section heading for breadcrumb (heading marker is stored in the first chunk)
const headingChunkId =
    ((indexes.sectionToChunks?.[collectionData.id] || {}) as Record<string, string[]>)[section]?.[0] ?? chunkId;
const headingChunk = headingChunkId ? await fetchExcerptChunk(headingChunkId, requestUrl) : null;
const headingExcerpt = headingChunk?.excerpts.find((e) => e.id === section) as Excerpt | undefined;

const sectionTitle = headingExcerpt?.text || `Section ${section}`;

// Format citation using the actual collection data
const citation = getCitationParts(excerpt, collectionData);
marked.setOptions({ breaks: true });

const citationMarkdown = `[${citation.label}](${citation.url})`;
const englishHtml = marked.parse(excerpt.text);
const copyPayload = `${excerpt.nass}\n\n${excerpt.text}\n\n${citationMarkdown}`;

const translators = Array.isArray(translatorsData)
    ? translatorsData
    : ((translatorsData as { translators?: Array<{ id: number; name: string }> }).translators ?? []);
const translatorName = translators.find((translator) => translator.id === excerpt.translator)?.name;

const excerptWords = excerpt.text.split(/\s+/).filter(Boolean);
const excerptPreview = excerptWords.slice(0, 8).join(' ');
const excerptLabel = excerptWords.length > 8 ? `${excerptPreview}…` : excerptPreview;
const currentExcerptIndex = sectionExcerptList.indexOf(excerptId);
const currentExcerptNumber = currentExcerptIndex >= 0 ? currentExcerptIndex + 1 : 1;
const totalExcerptsInSection = sectionExcerptList.length;
const previousExcerptId = currentExcerptIndex > 0 ? sectionExcerptList[currentExcerptIndex - 1] : null;
const nextExcerptId =
    currentExcerptIndex >= 0 && currentExcerptIndex < sectionExcerptList.length - 1
        ? sectionExcerptList[currentExcerptIndex + 1]
        : null;

async function loadSectionExcerptSummary(targetExcerptId: string | null) {
    if (!targetExcerptId) {
        return null;
    }

    const targetChunkId = excerptToChunk[targetExcerptId];
    if (!targetChunkId) {
        return null;
    }

    const targetChunk = targetChunkId === chunkId ? initialChunk : await fetchExcerptChunk(targetChunkId, requestUrl);
    const targetExcerpt = targetChunk?.excerpts.find((candidate) => candidate.id === targetExcerptId);

    if (!targetExcerpt) {
        return null;
    }

    const previewWords = targetExcerpt.text.split(/\s+/).filter(Boolean);
    const preview = previewWords.slice(0, 12).join(' ');

    return {
        id: targetExcerptId,
        href: `/browse/${collectionSlug}/${section}/e/${targetExcerptId}`,
        preview: previewWords.length > 12 ? `${preview}…` : preview,
    };
}

const previousExcerpt = await loadSectionExcerptSummary(previousExcerptId);
const nextExcerpt = await loadSectionExcerptSummary(nextExcerptId);

const meta = excerpt.meta;
const hadithMeta = meta && 'num' in meta ? meta : null;
const bookMeta = meta && 'vol' in meta ? meta : null;

const formatHadithNumber = (num?: string) => {
    if (!num) {
        return null;
    }
    const western = arabicToWestern(num);
    return Number.isNaN(western) ? num : western.toString();
};

const breadcrumbItems = [
    { label: 'Browse', href: '/browse' },
    { label: collectionData.roman, href: `/browse/${collectionSlug}` },
    { label: sectionTitle, href: `/browse/${collectionSlug}/${section}` },
    { label: excerptLabel || 'Excerpt' },
];

// Biome doesn't see template usage in .astro files.
void BilingualText;
void CitationBlock;
void ThemeToggle;
void Footer;
void Header;
void Breadcrumb;
void collectionsData;
void indexesData;
void translatorsData;
void BaseLayout;
void arabicToWestern;
void getCitationParts;
void citationMarkdown;
void englishHtml;
void copyPayload;
void translatorName;
void meta;
void hadithMeta;
void bookMeta;
void formatHadithNumber;
void breadcrumbItems;
void previousExcerpt;
void nextExcerpt;

// Set cache headers for edge caching
Astro.response.headers.set('Cache-Control', 'public, s-maxage=3600, stale-while-revalidate=86400');
Astro.response.headers.set('CDN-Cache-Control', 'max-age=3600');
---

<BaseLayout
    title={`Excerpt ${excerptId}`}
    description={excerpt.text.slice(0, 160)}
>
    <Header slot="header" currentPath="/browse">
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <article class="excerpt-container">
        <Breadcrumb items={breadcrumbItems} />

        <div class="excerpt-content">
            <!-- Bilingual Text Blocks -->
            <div class="text-blocks">
                <div id="arabic-content" class="text-block arabic-block" role="article" aria-label="Arabic text">
                    <div class="language-indicator">العربية</div>
                    <BilingualText 
                      text={excerpt.nass} 
                      isArabic={true} 
                      className="text-block-inner" 
                    />
                </div>
                <div id="english-content" class="text-block english-block" lang="en" dir="ltr" role="article">
                    <div class="language-indicator">English</div>
                    <div class="english-markdown" set:html={englishHtml} />
                </div>
            </div>

            <!-- Citation Block -->
            <CitationBlock excerpt={excerpt} collection={collectionData} />
            <div class="share-actions" aria-label="Copy excerpt">
                <ShareButton text={copyPayload} ariaLabel="Copy excerpt and citation" />
            </div>

            <!-- Metadata Details -->
            <section class="metadata-section">
                <h2 class="sr-only">Additional Metadata</h2>
                <dl class="metadata-list">
                    <div class="metadata-item">
                        <dt>Page</dt>
                        <dd>{excerpt.from}</dd>
                    </div>
                    {
                        hadithMeta && (
                            <div class="metadata-item">
                                <dt>Hadith Number</dt>
                                <dd>#{formatHadithNumber(hadithMeta.num)}</dd>
                            </div>
                        )
                    }
                    {
                        bookMeta && (
                            <div class="metadata-item">
                                <dt>Volume</dt>
                                <dd>
                                    {bookMeta.vol}
                                    {bookMeta.vp && ` / Page ${bookMeta.vp}`}
                                </dd>
                            </div>
                        )
                    }
                    <div class="metadata-item">
                        <dt>Translator</dt>
                        <dd>{translatorName || excerpt.translator}</dd>
                    </div>
                </dl>
            </section>

            {
                (previousExcerpt || nextExcerpt) && (
                    <section class="excerpt-pager-section" aria-labelledby="excerpt-pager-title">
                        <div class="excerpt-pager-header">
                            <h2 id="excerpt-pager-title">Section navigation</h2>
                            <p class="excerpt-pager-status">
                                Excerpt {currentExcerptNumber} of {totalExcerptsInSection}
                            </p>
                        </div>

                        <nav class="excerpt-pagination" aria-label="Excerpt navigation">
                            {previousExcerpt ? (
                                <a class="excerpt-pagination-link" href={previousExcerpt.href}>
                                    <span class="excerpt-pagination-label">Previous excerpt</span>
                                    <strong class="excerpt-pagination-target">← {previousExcerpt.id}</strong>
                                    <span class="excerpt-pagination-preview">{previousExcerpt.preview}</span>
                                </a>
                            ) : (
                                <div class="excerpt-pagination-link is-disabled" aria-hidden="true">
                                    <span class="excerpt-pagination-label">Previous excerpt</span>
                                    <strong class="excerpt-pagination-target">Start of section</strong>
                                </div>
                            )}
                            {nextExcerpt ? (
                                <a class="excerpt-pagination-link" href={nextExcerpt.href}>
                                    <span class="excerpt-pagination-label">Next excerpt</span>
                                    <strong class="excerpt-pagination-target">{nextExcerpt.id} →</strong>
                                    <span class="excerpt-pagination-preview">{nextExcerpt.preview}</span>
                                </a>
                            ) : (
                                <div class="excerpt-pagination-link is-disabled" aria-hidden="true">
                                    <span class="excerpt-pagination-label">Next excerpt</span>
                                    <strong class="excerpt-pagination-target">End of section</strong>
                                </div>
                            )}
                        </nav>
                    </section>
                )
            }
        </div>
    </article>

    <Footer slot="footer" />
</BaseLayout>

<style>
    .excerpt-container {
        max-width: 800px;
        margin: 0 auto;
        padding: var(--space-8) var(--space-6);
    }

    .excerpt-content {
        margin-top: var(--space-8);
        display: flex;
        flex-direction: column;
        gap: var(--space-10);
    }

    .excerpt-skip-links {
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-3);
        font-size: var(--text-sm);
    }

    .excerpt-skip-links a {
        color: var(--color-primary-text);
        text-decoration: none;
    }

    .excerpt-skip-links a:hover {
        text-decoration: underline;
    }

    .text-blocks {
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
    }

    .text-block {
        padding: var(--space-6);
        border-radius: var(--radius-lg);
    }

    .text-block-inner {
        display: block;
    }

    .language-indicator {
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: var(--space-3);
    }

    .arabic-block {
        background-color: var(--color-arabic-bg);
        font-size: var(--text-xl);
    }

    .english-block {
        background-color: var(--color-english-bg);
        font-size: var(--text-lg);
        color: var(--color-text-secondary);
    }

    .english-markdown {
        white-space: pre-wrap;
        overflow-wrap: anywhere;
        word-break: break-word;
    }

    .english-markdown :global(p) {
        margin: 0;
    }

    .english-markdown :global(p + p) {
        margin-top: var(--space-3);
    }

    .metadata-section {
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-6);
    }

    .metadata-list {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: var(--space-6);
    }

    .metadata-item {
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .metadata-item dt {
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.1em;
    }

    .metadata-item dd {
        font-family: var(--font-mono);
        font-size: var(--text-sm);
        color: var(--color-text-primary);
    }

    .excerpt-pager-section {
        border-top: 1px solid var(--color-border);
        padding-top: var(--space-6);
    }

    .excerpt-pager-header {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
        gap: var(--space-4);
        margin-bottom: var(--space-4);
        flex-wrap: wrap;
    }

    .excerpt-pager-header h2 {
        margin: 0;
        font-size: var(--text-lg);
        color: var(--color-text-primary);
    }

    .excerpt-pager-status {
        margin: 0;
        color: var(--color-text-tertiary);
        font-size: var(--text-sm);
    }

    .excerpt-pagination {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: var(--space-4);
    }

    .excerpt-pagination-link {
        min-height: 7.5rem;
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: var(--space-5);
        background-color: var(--color-surface);
        display: flex;
        flex-direction: column;
        align-items: flex-start;
        justify-content: center;
        gap: var(--space-2);
        color: inherit;
        text-decoration: none;
        transition:
            border-color var(--duration-fast) var(--ease-out),
            box-shadow var(--duration-fast) var(--ease-out),
            transform var(--duration-fast) var(--ease-out);
    }

    .excerpt-pagination-link:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-md);
        transform: translateY(-1px);
    }

    .excerpt-pagination-label {
        font-size: var(--text-xs);
        font-weight: 600;
        color: var(--color-text-tertiary);
        text-transform: uppercase;
        letter-spacing: 0.08em;
    }

    .excerpt-pagination-target {
        font-size: var(--text-base);
        color: var(--color-primary-text);
        font-family: var(--font-mono);
        line-height: 1.2;
    }

    .excerpt-pagination-preview {
        color: var(--color-text-secondary);
        line-height: 1.5;
        overflow: hidden;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        text-align: left;
    }

    .excerpt-pagination-link.is-disabled {
        opacity: 0.65;
        cursor: default;
        pointer-events: none;
        box-shadow: none;
        transform: none;
    }

    @media (max-width: 640px) {
        .metadata-list {
            grid-template-columns: 1fr;
        }

        .excerpt-pagination {
            grid-template-columns: 1fr;
        }
    }
</style>
