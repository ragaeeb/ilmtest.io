---
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

// Biome doesn't see template usage in .astro files.
void ThemeToggle;
void Footer;
void Header;
void BaseLayout;
---

<BaseLayout title="Terms of Use">
  <Header slot="header" currentPath="/terms">
    <ThemeToggle client:only="react" slot="theme-toggle" />
  </Header>

  <div class="policy-container">
    <h1 class="page-title">Terms of Use</h1>
    <p class="updated-text">Last updated: January 24, 2026</p>

    <section class="policy-section">
      <h2>Acceptance</h2>
      <p>
        By accessing IlmTest, you agree to these terms. If you do not agree, please do not use the site.
      </p>
    </section>

    <section class="policy-section">
      <h2>Use of Content</h2>
      <ul>
        <li>Content is provided for educational and research purposes.</li>
        <li>Do not misrepresent translations as original sources.</li>
        <li>Do not use the site to distribute inaccurate or altered content.</li>
      </ul>
    </section>

    <section class="policy-section">
      <h2>Availability</h2>
      <p>
        We may modify or discontinue the service at any time. We are not liable for downtime or data loss.
      </p>
    </section>

    <section class="policy-section">
      <h2>External Links</h2>
      <p>
        Source links lead to third-party sites. We are not responsible for their content or availability.
      </p>
    </section>

    <section class="policy-section">
      <h2>Contact</h2>
      <p>
        Questions about these terms can be sent to <a href="mailto:hello@ilmtest.io">hello@ilmtest.io</a>.
      </p>
    </section>
  </div>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .policy-container {
    max-width: 800px;
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
  }

  .page-title {
    font-size: var(--text-3xl);
    color: var(--color-text-primary);
    margin-bottom: var(--space-2);
  }

  .updated-text {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
    margin-bottom: var(--space-8);
  }

  .policy-section {
    margin-bottom: var(--space-8);
  }

  .policy-section h2 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }

  .policy-section p,
  .policy-section li {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
  }

  .policy-section ul {
    padding-left: var(--space-6);
  }
</style>
