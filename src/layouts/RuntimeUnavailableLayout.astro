---
import { ThemeToggle } from '@/components/islands/ThemeToggle';
import Footer from '@/components/layout/Footer.astro';
import Header from '@/components/layout/Header.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';

interface Props {
    title?: string;
    message?: string;
    backHref?: string;
    backLabel?: string;
}

const {
    title = 'Temporarily unavailable',
    message = 'Corpus data is temporarily unavailable. Please try again shortly.',
    backHref = '/browse',
    backLabel = 'Return to browse',
} = Astro.props as Props;
---

<BaseLayout title={title} description={message}>
    <Header slot="header" currentPath={backHref}>
        <ThemeToggle client:only="react" slot="theme-toggle" />
    </Header>

    <main class="runtime-unavailable">
        <div class="runtime-unavailable-card">
            <p class="eyebrow">Runtime data</p>
            <h1>{title}</h1>
            <p>{message}</p>
            <a href={backHref}>{backLabel}</a>
        </div>
    </main>

    <Footer slot="footer" />
</BaseLayout>

<style>
    .runtime-unavailable {
        max-width: 960px;
        margin: 0 auto;
        padding: var(--space-12) var(--space-6);
    }

    .runtime-unavailable-card {
        border: 1px solid var(--color-border);
        border-radius: var(--radius-xl);
        background: var(--color-surface);
        padding: var(--space-10);
        text-align: center;
        box-shadow: var(--shadow-sm);
    }

    .eyebrow {
        font-size: var(--text-sm);
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--color-text-tertiary);
        margin-bottom: var(--space-3);
    }

    h1 {
        font-size: var(--text-3xl);
        margin-bottom: var(--space-4);
        color: var(--color-text-primary);
    }

    p {
        max-width: 42rem;
        margin: 0 auto var(--space-6);
        color: var(--color-text-secondary);
    }

    a {
        color: var(--color-primary-text);
        text-decoration: underline;
        text-underline-offset: 2px;
    }
</style>
